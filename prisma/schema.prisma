// Prisma Schema for Builddeck
// Using PostgreSQL (Neon) for production

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// ENUMS (SQLite doesn't support enums, using String)
// =====================================================

// Role: USER, ADMIN
// ProductStatus: PENDING, APPROVED, REJECTED
// SubmissionAction: SUBMITTED, APPROVED, REJECTED, RESUBMITTED, FEATURED, UNFEATURED

// =====================================================
// MODELS
// =====================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String?   @unique
  password      String?   // Optional for magic-link auth
  role          String    @default("USER") // USER, ADMIN
  avatarUrl     String?
  bio           String?
  website       String?
  twitter       String?
  emailVerified DateTime?
  
  // Relations
  accounts      Account[]
  sessions      Session[]
  products      Product[]
  builds        Build[]
  submissions   Submission[] @relation("UserSubmissions")
  reviewedProducts Product[] @relation("ReviewedBy")
  performedActions Submission[] @relation("PerformedBy")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Build {
  id        String   @id @default(cuid())
  userId    String
  idea      String
  output    Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Category {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  description   String?
  icon          String?   // Emoji or icon name
  color         String?   // Hex color
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  
  // Relations
  products      Product[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Product {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  tagline         String
  description     String?
  websiteUrl      String
  logoUrl         String?
  screenshots     String    @default("[]") // JSON array stored as string
  
  // Status & Features
  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  featured        Boolean   @default(false)
  featuredAt      DateTime?
  
  // Metrics
  viewCount       Int       @default(0)
  upvoteCount     Int       @default(0)
  
  // Moderation
  rejectionReason String?
  reviewedAt      DateTime?
  
  // Relations
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId      String?
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  
  reviewedById    String?
  reviewedBy      User?     @relation("ReviewedBy", fields: [reviewedById], references: [id])
  
  submissions     Submission[]
  socialPosts     SocialPost[]
  
  // Timestamps
  submittedAt     DateTime  @default(now())
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([featured])
  @@index([userId])
  @@index([categoryId])
  @@index([slug])
}

model Submission {
  id              String    @id @default(cuid())
  action          String    // SUBMITTED, APPROVED, REJECTED, RESUBMITTED, FEATURED, UNFEATURED
  previousStatus  String?
  newStatus       String?
  notes           String?   // Admin notes or rejection reason
  
  // Relations
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User      @relation("UserSubmissions", fields: [userId], references: [id], onDelete: Cascade)
  
  performedById   String?
  performedBy     User?     @relation("PerformedBy", fields: [performedById], references: [id])
  
  createdAt       DateTime  @default(now())

  @@index([productId])
  @@index([userId])
  @@index([action])
}

model NewsletterSubscriber {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  confirmed         Boolean   @default(false)
  confirmationToken String?   @unique
  confirmedAt       DateTime?
  unsubscribed      Boolean   @default(false)
  unsubscribedAt    DateTime?
  source            String    @default("website")
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([email])
  @@index([confirmed])
}

model WaitlistLead {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

// Social post drafts for X (Twitter) and LinkedIn
model SocialPost {
  id              String    @id @default(cuid())
  
  // Platform: X, LINKEDIN
  platform        String
  
  // Status: DRAFT, SCHEDULED, PUBLISHED, FAILED
  status          String    @default("DRAFT")
  
  // Content
  content         String    // The post text
  
  // Publishing details
  publishedAt     DateTime?
  publishedId     String?   // External post ID from the platform
  errorMessage    String?   // If publishing failed
  
  // Relations
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([productId])
  @@index([platform])
  @@index([status])
}
