# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# SMTP (Hostinger)
EMAIL_SERVER_HOST=smtp.hostinger.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_SECURE=true
EMAIL_SERVER_USER=hello@builddeck.io
EMAIL_SERVER_PASSWORD=your_mailbox_password
EMAIL_FROM=BuildDeck <hello@builddeck.io>

# Hostinger Reach (Maker Digest contacts)
HOSTINGER_API_TOKEN=your_hostinger_api_token
HOSTINGER_REACH_PROFILE_UUID=optional_profile_uuid_for_maker_digest
HOSTINGER_REACH_WELCOME_MANAGED=false

# Auth
NEXTAUTH_SECRET=your_nextauth_secret
DATABASE_URL=your_postgres_connection_url

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
